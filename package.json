{
  "name": "@nexus-spec/cli",
  "version": "2.0.0",
  "description": "nxsp - NexusSpec CLI with deep OpenSpec 1.3 integration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nxsp": "./bin/nxsp.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "ui:dev": "vite --config vite.ui.config.ts",
    "ui:build": "vite build --config vite.ui.config.ts",
    "ui:preview": "vite preview --config vite.ui.config.ts"
  },
  "keywords": ["spec", "cli", "nexus", "openspec"],
  "author": "NexusSpec Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@fission-ai/openspec": "^1.3.0",
    "commander": "^14.0.0",
    "chalk": "^5.5.0",
    "ora": "^8.2.0",
    "yaml": "^2.8.2",
    "zod": "^4.0.17",
    "readline-sync": "^1.4.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reactflow": "^11.11.4",
    "lucide-react": "^0.468.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@types/node": "^24.2.0",
    "@types/readline-sync": "^1.4.8",
    "typescript": "^5.9.3",
    "eslint": "^9.39.2",
    "typescript-eslint": "^8.50.1",
    "vitest": "^3.2.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.0"
  }
}